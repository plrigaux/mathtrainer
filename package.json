{
  "name": "mathtrainer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "fr": "ng serve --configuration=fr",
    "en": "ng serve --configuration=en-US",
    "extract": "ng extract-i18n --output-path=src/locale --format=xlf2",
    "extract-merge": "npm run extract && npm run merge",
    "merge": "xliffmerge --profile xliffmerge.json fr",
    "build4git": "ng build --base-href https://plrigaux.github.io/mathtrainer",
    "deploy4git": "npx angular-cli-ghpages -d dist/mathtrainer",
    "fulldeploy": "npm run build4git && npm run deploy4git"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^17.3.5",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^17.3.5",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "rxjs": "~6.6.0",
    "tslib": "^2.2.0",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.5",
    "@angular/cli": "^17.3.5",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/localize": "^18.2.14",
    "@types/jasmine": "~3.6.0",
    "@types/node": "^12.11.1",
    "jasmine-core": "~3.10.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.7.0",
    "typescript": "~5.4.5"
  }
}
