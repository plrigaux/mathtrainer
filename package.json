{
  "name": "mathtrainer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "fr": "ng serve --configuration=fr",
    "en": "ng serve --configuration=en-US",
    "extract": "ng extract-i18n --output-path=src/locale --format=xlf2",
    "extract-merge": "npm run extract && npm run merge",
    "merge": "xliffmerge --profile xliffmerge.json fr",
    "build4git": "ng build --base-href https://plrigaux.github.io/mathtrainer",
    "deploy4git": "npx angular-cli-ghpages -d dist/mathtrainer",
    "fulldeploy": "npm run build4git && npm run deploy4git"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "21.2.8",
    "@angular/router": "^21.2.8",
    "rxjs": "~7.8.2",
    "tslib": "^2.2.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@angular/localize": "^21.2.8",
    "@types/jasmine": "~6.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "typescript": "~5.9.3"
  }
}
